{
  "name": "cc-financial",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash -c 'source .env && TZ=Asia/Bangkok DATABASE_URL=$DATABASE_URL_DEV next dev --turbopack'",
    "dev:db:push": "bash -c 'source .env && TZ=Asia/Bangkok DATABASE_URL=$DATABASE_URL_DEV DATABASE_URL_UNPOOLED=$DATABASE_URL_DEV npx prisma db push'",
    "dev:db:studio": "bash -c 'source .env && TZ=Asia/Bangkok DATABASE_URL=$DATABASE_URL_DEV npx prisma studio'",
    "db:sync": "node scripts/db-sync.mjs",
    "build": "TZ=Asia/Bangkok next build --webpack",
    "vercel-build": "prisma generate && node scripts/clear-migrate-lock.mjs && DATABASE_URL=\"${APP_DATABASE_URL:-$DATABASE_URL}\" DATABASE_URL_UNPOOLED=\"${APP_DATABASE_URL_UNPOOLED:-$DATABASE_URL_UNPOOLED}\" prisma migrate deploy && esbuild payload.config.ts --bundle --format=esm --platform=node --packages=external --outfile=payload.config.bundle.mjs && NODE_ENV=development PAYLOAD_DATABASE_URI=\"$DATABASE_URL_UNPOOLED\" node scripts/payload-push.mjs &&TZ=Asia/Bangkok next build --webpack",
    "start": "TZ=Asia/Bangkok next start",
    "lint": "eslint",
    "cleanup:financial": "node scripts/cleanupFinancialRecords.mjs",
    "payload": "PAYLOAD_CONFIG_PATH=payload.config.ts payload",
    "payload:generate:importmap": "PAYLOAD_CONFIG_PATH=payload.config.ts payload generate:importmap",
    "payload:generate:types": "PAYLOAD_CONFIG_PATH=payload.config.ts payload generate:types"
  },
  "dependencies": {
    "@paper-design/shaders-react": "^0.0.61",
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-vercel-blob": "^3.85.2",
    "@payloadcms/translations": "^3.84.1",
    "@prisma/client": "^6.19.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "@studio-freight/lenis": "^1.0.42",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.8.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "geist": "^1.5.1",
    "googleapis": "^160.0.0",
    "graphql": "^16.14.0",
    "leva": "^0.10.0",
    "lucide-react": "^0.544.0",
    "maath": "^0.10.8",
    "next": "^16.0.7",
    "next-themes": "^0.4.6",
    "path": "^0.12.7",
    "payload": "^3.84.1",
    "pg": "^8.16.3",
    "r3f-perf": "^7.2.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.2.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.1",
    "three": "^0.180.0",
    "url": "^0.11.4"
  },
