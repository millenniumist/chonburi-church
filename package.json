    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.33",
    "@tailwindcss/postcss": "^4",
    "cheerio": "^1.1.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
