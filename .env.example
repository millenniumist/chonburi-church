# Copy to .env.local for development:  cp .env.example .env.local
# Only DATABASE_URL is required; everything else has a sensible default.

# Postgres. Drizzle owns this schema (drizzle-kit generate/migrate).
# Local dev uses the `dev-up` skill container (cag-postgres on port 5433).
DATABASE_URL="postgresql://cag:cag@localhost:5433/coffee_and_gospel"
# Production (Vercel + Neon — see deployment/VERCEL.md and ADR-0006): use Neon's
# POOLED connection string (host contains `-pooler`), e.g.
#   DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Per-process pg pool size (default 1 — right for serverless). Raise on a long-lived host.
# DB_POOL_MAX="1"
# Runtime timezone (set in the Vercel project env; build scripts pass it locally).
# TZ="Asia/Bangkok"

# Public site URL — used for metadata/sitemap. Falls back to localhost in dev.
# NEXT_PUBLIC_SITE_URL="https://example.com"

# Session cookie name (optional; defaults to cag_session).
# SESSION_COOKIE_NAME="cag_session"

# Seed admin (used by `npm run db:seed`).
SEED_ADMIN_EMAIL="admin@church.local"
SEED_ADMIN_PASSWORD="change-me-now"
SEED_ADMIN_NAME="Café Admin"
